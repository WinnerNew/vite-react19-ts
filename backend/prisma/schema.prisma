generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  handle    String    @unique
  avatar    String    @db.LongText
  bio       String?   @db.Text
  location  String?
  website   String?
  password  String
  followers Int       @default(0)
  following Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  chats1    Chat[]    @relation("User1Chats")
  chats2    Chat[]    @relation("User2Chats")
  messages  Message[]
  posts     Post[]
  likedPosts Like[]
  reposts    Repost[]
  
  // 关注逻辑
  followersList Follow[] @relation("follower")
  followingList Follow[] @relation("following")

  // 通知关联
  notifications         Notification[] @relation("recipient")
  triggeredNotifications Notification[] @relation("actor")

  @@map("users")
}

model Notification {
  id          String   @id @default(cuid())
  type        String   // "LIKE", "REPOST", "REPLY", "FOLLOW", "MESSAGE"
  postId      String?  // 相关的帖子ID
  messageId   String?  // 相关的消息ID
  actorId     String   // 触发动作的用户ID
  recipientId String   // 接收通知的用户ID
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  actor     User @relation("actor", fields: [actorId], references: [id])
  recipient User @relation("recipient", fields: [recipientId], references: [id])
  
  post    Post?    @relation(fields: [postId], references: [id])
  message Message? @relation(fields: [messageId], references: [id])

  @@index([recipientId])
  @@index([actorId])
  @@map("notifications")
}

model Post {
  id        String   @id @default(cuid())
  content   String   @db.Text
  image     String?  @db.LongText
  likesCount Int      @default(0)
  repostsCount Int      @default(0)
  repliesCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  // 关联字段
  likes     Like[]
  reposts   Repost[]
  notifications Notification[]
  
  // 评论/回复逻辑
  parentId  String?
  parent    Post?    @relation("PostReplies", fields: [parentId], references: [id])
  replies   Post[]   @relation("PostReplies")

  @@index([userId], map: "Post_userId_fkey")
  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@map("likes")
}

model Repost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@map("reposts")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("following", fields: [followerId], references: [id])
  following   User     @relation("follower", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("follows")
}

model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  chatId  String
  chat    Chat     @relation(fields: [chatId], references: [id])
  
  notifications Notification[]

  @@map("messages")
}

model Chat {
  id          String   @id @default(cuid())
  unreadCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user1Id     String
  user2Id     String
  user1       User     @relation("User1Chats", fields: [user1Id], references: [id])
  user2       User     @relation("User2Chats", fields: [user2Id], references: [id])
  messages    Message[]

  @@unique([user1Id, user2Id])
  @@map("chats")
}
